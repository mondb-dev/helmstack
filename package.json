{
  "name": "helmstack",
  "version": "0.1.0",
  "private": true,
  "description": "AI-native browser substrate — perception and execution layer for autonomous agents",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @helmstack/desktop",
    "build:packages": "npm run build -w packages/shared -w packages/perception -w packages/agent-sdk -w packages/mcp-server",
    "dev": "npm run dev -w @helmstack/desktop",
    "serve:test-pages": "node apps/desktop/scripts/serve-test-pages.mjs",
    "test": "vitest run",
    "test:perception": "vitest run",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "multi-semantic-release": "^3.0.2",
    "semantic-release": "^24.2.3",
    "tsup": "^8.4.0",
    "vitest": "^3.2.4"
  }
}
